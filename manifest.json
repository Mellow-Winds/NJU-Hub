{
  "manifest_version": 3,
  "name": "NJU Hub - 南大智慧终端",
  "version": "2.0.1",
  "description": "个人学术指挥中心：GPA静默监控 | 课表抓取 | 自动登录 | LMS增强",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.nju.edu.cn/*",
    "http://elite.nju.edu.cn/*",
    "https://api.siliconflow.cn/*",
    "https://api.openai.com/*",
    "https://open.bigmodel.cn/*"
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": "icons/icon128.png"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://authserver.nju.edu.cn/authserver/login*"],
      "js": ["scripts/login.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "*://ehallapp.nju.edu.cn/jwapp/sys/wdkb/*",
        "*://xk.nju.edu.cn/xsxkapp/*"
      ],
      "js": [
        "libs/xlsx.full.min.js",
        "scripts/course_helper.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": ["http://elite.nju.edu.cn/exchangesystem/*"],
      "js": ["scripts/gpa.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://lms.nju.edu.cn/*"],
      "js": ["scripts/lms.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["*://ehallapp.nju.edu.cn/jwapp/sys/wspjyyapp/*"],
      "js": ["scripts/eval.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["*://p-nju.seec.seecoder.cn/*"],
      "js": ["scripts/seec_workpanel_enhance_v22.js"],
      "run_at": "document_end"
    }
  ]
}